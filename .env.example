# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Your Telegram chat ID (send /start to @userinfobot to find yours)
ALLOWED_CHAT_ID=6237832337

# Anthropic API key — optional, only needed for the reflection pass
ANTHROPIC_API_KEY=sk-ant-...

# Path to homelabber engine — default works if repo layout is unchanged
# HOMELABBER_PATH=/home/lowflying/talon/homelabber

# Project root for path validation — default works for standard layout
# ALLOWED_PROJECT_ROOT=/home/lowflying/talon

# Claude execution timeout in seconds (default: 600)
# CLAUDE_TIMEOUT=600

# Separate token for E2E tests — optional
# TELEGRAM_TEST_BOT_TOKEN=
